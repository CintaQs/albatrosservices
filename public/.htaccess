# ==============================================================================
# STRATO BARE-METAL ROUTING & UTF-8 ENFORCEMENT
# ==============================================================================
AddDefaultCharset UTF-8

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Force HTTPS (Critical for Strato)
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # 2. Astro Directory Trailing-Slash Normalization
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !^/$
  RewriteRule ^(.*[^/])$ /$1/ [L,R=301]
</IfModule>

<IfModule mod_headers.c>
  # 3. Explicit UTF-8 Header for raw text (robots, humans, llms)
  <FilesMatch "\.(txt)$">
    Header set Content-Type "text/plain; charset=utf-8"
  </FilesMatch>

  # 3.1 Explicit UTF-8 XML Declaration for Sitemaps (Critical for Google Search Console)
  <FilesMatch "\.(xml)$">
    Header set Content-Type "application/xml; charset=utf-8"
  </FilesMatch>

# 4. HSTS (HTTP Strict Transport Security) - Force HTTPS for 1 year, include subdomains
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

# 2. X-Frame-Options - Prevent Clickjacking (Only allow framing by same origin)
Header always set X-Frame-Options "SAMEORIGIN"

# 3. X-Content-Type-Options - Prevent MIME-Sniffing (Force browsers to respect declared Content-Type)
Header always set X-Content-Type-Options "nosniff"

# 4. Referrer-Policy - Privacy protection (Hide full URL paths from external domains)
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# 5. X-XSS-Protection - Legacy cross-site scripting filter
Header always set X-XSS-Protection "1; mode=block"

# 6. Content Security Policy (Basic) - Prevent mixed content and restrict origins
Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-ancestors 'self';"
</IfModule>

# Deflate Compression (Gzip) for static assets
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml text/plain
</IfModule>

# Better Cache Control for static assets (Busting via Astro hashes)
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType font/woff2 "access plus 1 year"
ExpiresDefault "access plus 2 days"
</IfModule>

# Protect sensitive files from being read directly (Excludes .well-known for AutoSSL)
<FilesMatch "^\.env|^\.git|^\.ht|^\.github|^\.svn|\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist)|~|custom\.ini|vhost\.conf$">
Require all denied
</FilesMatch>

# Custom Error Pages (if you generate them via Astro)
ErrorDocument 404 /404.html

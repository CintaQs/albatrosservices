---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-container">

    <div class="footer-info">
      <a href="/" class="footer-logo-link" aria-label="Albatros Services Startseite">
        <picture>
  <source srcset="/images/albatros-logo-white.webp" type="image/webp" />
  <img src="/images/albatros-logo-white.png" alt="Albatros Services" class="footer-logo" width="221" height="65" />
</picture>
      </a>
      <p>Lohnkostenzuschüsse als Reingewinn.<br>Eine Marke der upgrade4you GmbH.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer Navigation">
      <h3>Navigation</h3>
      <ul class="footer-quick-links">
        <li><a href="#beispiele">Beispiele</a></li>
        <li><a href="#vorteile">Vorteile</a></li>
        <li><a href="#ablauf">Ablauf</a></li>
        <li><a href="#faq">FAQ</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <h3>Kontakt</h3>
      <ul class="footer-contact-list">
        <li>
          <svg class="contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <a href="tel:+4930232538776">Tel: 030 / 2325387-76</a>
        </li>
        <li>
          <svg class="contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          <a href="mailto:personalprojekt@albatrosservices.de">personalprojekt@albatrosservices.de</a>
        </li>
        <li class="contact-address-li">
          <svg class="contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <span>James-Franck-Str. 21<br>12489 Berlin-Adlershof</span>
        </li>
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-container">
      <p>&copy; {currentYear} Albatros Services. Alle Rechte vorbehalten.</p>
      <nav aria-label="Rechtliche Navigation">
        <ul class="footer-legal-links">
          <li><a href="/impressum">Impressum</a></li>
          <li><a href="/datenschutz">Datenschutz</a></li>
          <li><a href="/barrierefreiheit">Barrierefreiheit</a></li>
          <li><a href="/foerdermittel-wissen">Fördermittel-Wissen</a></li>
          <li class="btt-li">
            <button id="global-btt" class="btt-inline" aria-label="Zurück nach oben">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
              Nach oben
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const bttBtn = document.getElementById('global-btt');
    if (bttBtn) {
      bttBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }
  });
</script>

<style>
  .site-footer {
    background-color: var(--c-primary-dark);
    color: white;
    padding-top: var(--spacing-xl);
  }

  .footer-container {
    display: grid;
    grid-template-columns: 4fr 2fr 3fr;
    gap: 3rem;
    align-items: start;
    padding-top: 1rem;
    padding-bottom: 3.5rem;
  }

  @media (max-width: 900px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      gap: 2.5rem;
    }
  }

  /* Logo */
  .footer-logo-link {
    display: inline-block;
    margin-bottom: 2.25rem;
  }

  .footer-logo {
    height: 65px;
    width: auto;
    display: block;
  }

  /* Column headings */
  .footer-contact h3,
  .footer-nav h3 {
    color: var(--c-white);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-transform: none !important;
    letter-spacing: normal !important;
  }

  /* Body text */
  p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0.6rem;
  }

  /* Contact List Grid */
  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    line-height: 1.5;
    list-style-type: none !important;
    margin: 0;
    padding: 0;
  }

  .contact-icon {
    color: var(--c-accent);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Links */
  .footer-contact a,
  .footer-nav a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color var(--transition-fast);
  }

  .footer-contact a:hover,
  .footer-nav a:hover {
    color: var(--c-accent);
  }

  .footer-quick-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-quick-links li {
    margin-bottom: 0.6rem;
  }
  /* Nav list previously -> now handled globally */

  /* Copyright bar */
  .footer-bottom {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 1rem 0;
  }

  .footer-bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--c-white);
    opacity: 0.7;
  }

  .footer-legal-links {
    list-style-type: none !important;
    padding: 0;
    margin: 0;
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-legal-links li {
    list-style-type: none !important;
    margin: 0;
    padding: 0;
  }

  .footer-legal-links a {
    color: var(--c-white);
    text-decoration: none;
    font-size: 0.8rem;
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .footer-legal-links a:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .footer-bottom-container {
      flex-direction: column;
      justify-content: center;
      text-align: center;
    }
    .footer-legal-links {
      justify-content: center;
    }
  }

  /* Back to Top Inline Component */
  .footer-legal-links .btt-li {
    padding-left: 1.5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
  }
  
  .btt-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--c-white);
    transition: color var(--transition-fast);
  }
  
  .btt-inline svg {
    color: var(--c-accent);
  }
  
  .btt-inline:hover {
    color: var(--c-accent);
  }
</style>

<script>
  // Add Back To Top functionality
  document.addEventListener('DOMContentLoaded', () => {
    const bttBtn = document.getElementById('global-btt');
    if (bttBtn) {
      bttBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }
  });
</script>

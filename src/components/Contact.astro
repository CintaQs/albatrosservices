---
---
<section id="kontakt" class="contact-section section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info reveal-on-scroll reveal-delay-1">
        <h2 class="section-title contact-title reveal-on-scroll">Lassen Sie uns starten!</h2>
        <p class="subtitle">Wir können es kaum erwarten, auch Sie zu unseren Kunden zählen zu dürfen. Fordern Sie jetzt Ihre kostenlose Potenzialanalyse an.</p>
        
        <div class="info-blocks">
          <div class="info-block">
            <h3>Rufnummer</h3>
            <p>030 / 2325387-76</p>
          </div>
          <div class="info-block">
            <h3>E-Mail</h3>
            <p><a href="mailto:personalprojekt@albatrosservices.de" aria-label="E-Mail an Albatros Services senden">personalprojekt@albatrosservices.de</a></p>
          </div>

          <div class="info-block">
            <h3>Projektbüro</h3>
            <p>James-Franck-Str. 21<br>12489 Berlin-Adlershof</p>
          </div>
        </div>
      </div>
      
      <div class="contact-form-wrapper glass-panel reveal-on-scroll reveal-delay-2">
        <form class="contact-form" id="ajaxContactForm" method="POST" action="/contact.php">
          <h3>Kostenlose Potenzialanalyse anfordern</h3>
          
          <!-- Anti-Spam Honeypot (A11y hidden via class) -->
          <div class="sr-only" aria-hidden="true">
            <label for="fax_nummer">Faxnummer (Bitte leer lassen)</label>
            <input type="text" id="fax_nummer" name="fax_nummer" tabindex="-1" autocomplete="off">
          </div>

          <!-- CSRF Token (Double Submit Cookie pattern) -->

          
          <div class="form-group">
            <label for="company">Unternehmen</label>
            <input type="text" id="company" name="company" required placeholder="Ihr Firmenname" aria-required="true" autocomplete="organization">
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label for="name">Ansprechpartner</label>
              <input type="text" id="name" name="name" required placeholder="Ihr Name" aria-required="true" autocomplete="name">
            </div>
            <div class="form-group">
              <label for="email">E-Mail</label>
              <input type="email" id="email" name="email" required placeholder="Ihre E-Mail" aria-required="true" autocomplete="email">
            </div>
          </div>
          
          <div class="form-group">
            <label for="phone">Telefon (optional)</label>
            <input type="tel" id="phone" name="phone" placeholder="Für Rückfragen" autocomplete="tel">
          </div>
          
          <div class="form-group">
            <label for="message">Nachricht / Geplante Einstellungen</label>
            <textarea id="message" name="message" rows="4" placeholder="Teilen Sie uns gerne mit, für welche Positionen Sie in Kürze Einstellungen planen..."></textarea>
          </div>
          
          <div class="form-group checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" name="gdpr_consent" required aria-required="true">
              <span>Ich stimme zu, dass meine Angaben zur Kontaktaufnahme gespeichert werden. (Es gelten unsere <a href="/datenschutz" target="_blank" rel="noopener noreferrer">Datenschutzbestimmungen</a>)</span>
            </label>
          </div>
          
          <button type="submit" id="submitBtn" class="btn btn-primary btn-block" aria-label="Formular absenden">Potenzialanalyse anfordern</button>
          
          <div id="formStatus" class="form-status d-none" role="status" aria-live="polite"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    // --- Ajax Form Handler ---
    const form = document.getElementById('ajaxContactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const formStatus = document.getElementById('formStatus');

  if (form && submitBtn && formStatus) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Update UI to loading state
      const originalBtnText = submitBtn.textContent;
      submitBtn.textContent = 'Wird gesendet...';
      submitBtn.disabled = true;
      formStatus.className = 'form-status d-none';

      try {
        const formData = new FormData(form);
        // Post asynchronously to the Strato backend PHP script
        const response = await fetch('/contact.php', {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        // Read JSON response
        let result;
        try {
          result = await response.json();
        } catch(err) {
          throw new Error('Server antwortete nicht mit JSON. PHP Fehler auf dem Hosting?');
        }

        if (response.ok && result.status === 'success') {
          formStatus.textContent = result.message || 'Vielen Dank! Ihre Anfrage wurde erfolgreich gesendet.';
          formStatus.className = 'form-status success';
          form.reset(); // Clear the form
        } else {
          throw new Error(result.message || 'Ein Fehler ist aufgetreten.');
        }
      } catch (error) {
        formStatus.textContent = error instanceof Error ? error.message : 'Verbindungsfehler zum Server.';
        formStatus.className = 'form-status error';
      } finally {
        // Reset loading state
        submitBtn.textContent = originalBtnText;
        submitBtn.disabled = false;
      }
    });
  }
  }); // <-- CRITICAL: CLOSES DOMContentLoaded Listener
</script>

<style>
  .contact-section {
    background-color: var(--c-bg);
    position: relative;
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
    overflow: hidden;
  }

  .contact-title {
    text-align: left;
    margin-bottom: 2rem;
  }
  .contact-title::after {
    margin: 1rem 0 0 0;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    align-items: center; /* Vertically center left column against the taller form card */
    position: relative;
    z-index: 10;
  }
  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
  .subtitle {
    font-size: 1.125rem;
    color: var(--c-text-muted);
    margin-bottom: var(--spacing-md);
  }
  .info-blocks {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
  .info-block h3 {
    color: var(--c-accent);
    margin-bottom: 0.25rem;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .info-block p {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 500;
  }
  .info-block a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .info-block a:hover {
    color: var(--c-primary);
    text-decoration: underline;
  }
  @media (max-width: 768px) {
    .info-block a {
      word-break: break-all; /* Prevent 35 character email from bursting grid bounds */
    }
  }
  
  .contact-form-wrapper {
    background: var(--c-surface);
    padding: 3.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--c-border);
  }
  @media (max-width: 768px) {
    .contact-form-wrapper {
      padding: 1.5rem; /* Reclaim space for inputs on tiny phone screens */
    }
  }
  .contact-form h3 {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
  .form-group {
    margin-bottom: 1.25rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
  label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: var(--c-text);
    font-size: 0.9rem;
  }
  input, textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: all var(--transition-smooth);
    background: var(--c-surface);
    color: var(--c-text);
  }
  input::placeholder, textarea::placeholder {
    color: var(--c-text-muted);
  }
  textarea {
    resize: vertical; /* Prevent horizontal UI breaking */
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px rgba(0,75,135,0.1);
    background: var(--c-surface);
  }
  .btn-block {
    width: 100%;
    padding: 1rem;
    font-size: 1.125rem;
    margin-top: 0.5rem;
  }
  
  .form-status {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-align: center;
    animation: fadeIn var(--transition-fast);
  }
  .form-status.success {
    background-color: rgba(0, 200, 83, 0.1);
    color: #008b39;
    border: 1px solid #00c853;
  }
  .form-status.error {
    background-color: rgba(255, 61, 0, 0.1);
    color: #cc3000;
    border: 1px solid #ff3d00;
  }
  
  .form-disclaimer {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: var(--c-text-muted);
    text-align: center;
    line-height: 1.4;
  }
  
  .checkbox-group {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--c-text-muted);
    line-height: 1.4;
    cursor: pointer;
    font-weight: 400;
  }
  .checkbox-label input[type="checkbox"] {
    width: auto;
    margin-top: 0.15rem;
    cursor: pointer;
    flex-shrink: 0; /* Prevent squishing by consent text */
  }
  .checkbox-label input[type="checkbox"]:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
  }
  .checkbox-label a {
    color: var(--c-accent);
    text-decoration: underline;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
</style>

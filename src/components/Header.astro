---
---

<header class="site-header">
  <!-- Top Bar with important data -->
  <div class="top-bar">
    <div class="container top-bar-container">
      <div class="top-bar-contact">
        <a href="tel:+4930232538776" aria-label="Telefonnummer anrufen">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          030 / 2325387-76
        </a>
        <a href="mailto:personalprojekt@albatrosservices.de" aria-label="E-Mail schreiben">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          personalprojekt@albatrosservices.de
        </a>
      </div>
      <div class="top-bar-notice">
        <span class="status-dot"></span>
        <span>Zertifizierte Fördermittel-Experten</span>
      </div>
    </div>
  </div>

  <!-- Main Navigation Bar -->
  <div class="main-bar">
    <div class="container main-bar-container">
      <div class="logo">
        <a href="/" aria-label="Albatros Services Startseite">
          <picture>
  <source srcset="/images/albatros-logo.webp" type="image/webp" />
  <img src="/images/albatros-logo.png" alt="Albatros Services Logo" class="logo-img" width="160" height="47" />
</picture>
        </a>
      </div>
      
      <input type="checkbox" id="menu-toggle" class="menu-toggle sr-only" aria-label="Mobile Navigation umschalten" />
      <label class="mobile-menu-btn" for="menu-toggle" aria-label="Menü öffnen">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </label>
      
      <nav class="main-nav" aria-label="Hauptnavigation">
        <ul>
          <li><a href="/#beispiele" class="nav-link">Beispiele</a></li>
          <li><a href="/#vorteile" class="nav-link">Vorteile</a></li>
          <li><a href="/#ablauf" class="nav-link">Ablauf</a></li>
          <li><a href="/#faq" class="nav-link">FAQ</a></li>
          <li><a href="/#kontakt" class="btn btn-primary nav-btn">Potenzialanalyse anfordern</a></li>
        </ul>
      </nav>
    </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('.site-header');
    if (header) {
      const handleScroll = () => {
        if (window.scrollY > 20) {
          header.classList.add('is-scrolled');
        } else {
          header.classList.remove('is-scrolled');
        }
      };
      
      // Initial check
      handleScroll();
      // Passive listener for high 60fps performance
      window.addEventListener('scroll', handleScroll, { passive: true });
    }
  });
</script>

<style>
  .site-header {
    position: sticky; /* Reverted to sticky to repair document flow and Z-index rupture */
    top: 0;
    z-index: 1000;
    width: 100%;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Scrolled State Physics */
  .site-header.is-scrolled {
    /* Dynamic transform is now handled by JavaScript to support flexible heights */
  }

  /* Top Bar */
  .top-bar {
    background: linear-gradient(90deg, var(--c-primary-dark) 0%, var(--c-primary) 100%);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    min-height: 45px; /* Allows flexible growth on mobile */
  }
  .top-bar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 44px;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
  }
  .top-bar-contact {
    display: flex;
    gap: 2rem;
  }
  .top-bar-contact a {
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all var(--transition-fast);
  }
  .top-bar-contact a svg {
    color: var(--c-accent);
    transition: filter var(--transition-fast);
  }
  .top-bar-contact a:hover {
    color: white;
    opacity: 1;
  }
  .top-bar-contact a:hover svg {
    filter: drop-shadow(0 0 6px rgba(255, 107, 53, 0.6));
  }
  .top-bar-notice {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: rgba(255,255,255,0.95);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    background-color: var(--c-accent);
    border-radius: 50%;
    display: inline-block;
  }
  @media (max-width: 1024px) {
    .top-bar-notice {
      display: none;
    }
    .top-bar-container {
      justify-content: center;
      height: auto;
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }
    .top-bar-contact {
      flex-direction: column;
      gap: 0.25rem;
      align-items: center;
    }
    .top-bar-contact a {
      font-size: 0.8rem;
      padding: 0.25rem 0; /* Touch targets for phone/email */
      word-break: break-all; /* Prevent viewport burst from long email */
      text-align: center;
    }
  }

  /* Main Bar */
  .main-bar {
    background-color: var(--c-surface);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 20px rgba(0, 43, 82, 0.08); /* Initial soft shadow */
  }
  
  .site-header.is-scrolled .main-bar {
    background-color: rgba(255, 255, 255, 0.85); /* Frosted Glass Transition */
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 10px 30px rgba(0, 43, 82, 0.12); /* Deeper shadow when floating */
    border-bottom: 1px solid rgba(0, 43, 82, 0.05);
  }

  .main-bar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 90px;
    transition: height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .site-header.is-scrolled .main-bar-container {
    height: 70px; /* Compress the header dynamically */
  }
  
  .logo a {
    display: flex;
    align-items: center;
  }
  .logo-img {
    height: 47px; /* Prägnante Logo-Größe wie bei up4u */
    width: auto;
    display: block;
    /* Native transparent PNG eliminates the need for CSS blending hacks */
  }
  
  /* Inherits .sr-only from global.css instead of display:none to preserve Keyboard Focus */
  .menu-toggle:focus-visible + .mobile-menu-btn {
    outline: 3px solid var(--c-accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }
  .mobile-menu-btn {
    display: none;
    color: var(--c-primary-dark);
    cursor: pointer;
    padding: 0.5rem;
  }
  
  .main-nav ul {
    list-style: none;
    display: flex;
    gap: 2.5rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .main-nav a.nav-link {
    color: var(--c-text);
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    position: relative;
    padding: 0.5rem 1rem; /* Expanded for better touch target */
    display: block; /* Ensure full click area */
    transition: color var(--transition-fast);
  }
  
  /* AAA Spatial Hover Underline */
  .main-nav a.nav-link::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 2px;
    bottom: 0;
    left: 0;
    background-color: var(--c-accent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 2px;
  }
  
  .main-nav a.nav-link:hover {
    color: var(--c-accent);
  }
  
  .main-nav a.nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-btn {
    padding: 0.75rem 1.6rem;
    font-size: 1.05rem;
    /* Removed custom border-radius to mathematically inherit the Hero's pill-shape var(--radius-full) */
  }
  
  @media (max-width: 1024px) {
    .main-bar-container {
      height: 70px;
    }
    .logo-img {
      height: 38px;
    }
    .mobile-menu-btn {
      display: block;
    }
    .main-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--c-surface);
      border-top: 1px solid var(--c-border);
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      width: 100%;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: all var(--transition-smooth);
    }
    .main-nav ul {
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem 1.5rem;
      align-items: stretch;
      text-align: center;
    }
    .menu-toggle:checked ~ .main-nav {
      max-height: 500px;
      opacity: 1;
    }
  }
</style>

<script>
  // Mobile UX & AAA Scroll Physics
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('menu-toggle') as HTMLInputElement;
    const navLinks = document.querySelectorAll('.main-nav a');
    const siteHeader = document.querySelector('.site-header') as HTMLElement;

    // Auto-close mobile menu
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (menuToggle && menuToggle.checked) {
          menuToggle.checked = false;
        }
      });
    });

    // Glassmorphism Scroll Observer
    
    const handleScroll = () => {
      if (!siteHeader) return;
      
      const currentScrollY = window.scrollY;
      const topBar = document.querySelector('.top-bar') as HTMLElement;
      const topBarHeight = topBar ? topBar.offsetHeight : 45;
      
      if (currentScrollY > 40) {
        siteHeader.classList.add('is-scrolled');
        siteHeader.style.transform = `translateY(-${topBarHeight}px)`;
      } else {
        siteHeader.classList.remove('is-scrolled');
        siteHeader.style.transform = `translateY(0)`;
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    
    // Initial check
    handleScroll();
  });
</script>

---
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-ext-400.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-ext-600.css';
import '@fontsource/inter/latin-800.css';
import '@fontsource/inter/latin-ext-800.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
	title: string;
	description?: string;
  image?: string;
}

const { 
  title, 
  description = "Lohnkostenzuschüsse als Reingewinn - jeden Monat auf Ihrem Konto. Wir drehen Ihnen den Geldhahn auf.",
  image = "/og-image.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://albatrosservices.de');
---

<!DOCTYPE html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
    
    <!-- Security & Performance Standard -> 11/10 -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline';" />
    
    <link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon-512.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#004B87" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Albatros Services - Fördermittelberatung" />
    <meta property="og:site_name" content="Albatros Services" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
    
    <!-- Schema.org Baseline Identity (Global) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://albatrosservices.de/#website",
            "url": "https://albatrosservices.de",
            "name": "Albatros Services",
            "description": "Lohnkostenzuschüsse als Reingewinn - jeden Monat auf Ihrem Konto. Wir realisieren Ihre zustehenden Fördermittel völlig risikofrei nach SGB III.",
            "inLanguage": "de-DE"
          },
          {
            "@type": "Organization",
            "@id": "https://albatrosservices.de/#organization",
            "name": "upgrade4you GmbH",
            "url": "https://albatrosservices.de",
            "logo": {
              "@type": "ImageObject",
              "url": "https://albatrosservices.de/favicon.svg"
            }
          }
        ]
      }
    </script>
	</head>
	<body>
    <noscript>
      <div style="background-color: var(--c-primary-dark); color: white; padding: 1rem; text-align: center; font-family: system-ui, sans-serif; position: relative; z-index: 9999; font-weight: 500;">
        <strong>Hinweis:</strong> Für die optimale Darstellung und volle Funktionalität dieser B2B-Plattform empfehlen wir, JavaScript zu aktivieren. Sie erreichen uns jederzeit direkt unter <strong>030 / 2325387-76</strong>.
      </div>
    </noscript>
		<Header />
		<main id="main-content">
			<slot />
		</main>
		<Footer />
		<script>
      // 11/10 Cinematic Scroll Observer Architecture (Dynamic Engine)
      document.addEventListener('DOMContentLoaded', () => {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.15
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              observer.unobserve(entry.target); 
            }
          });
        }, observerOptions);



        // Globally observe ALL elements with the reveal utility class
        document.querySelectorAll('.reveal-on-scroll').forEach(el => {
          observer.observe(el);
        });
      });
		</script>
	</body>
</html>

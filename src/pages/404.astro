---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Seite nicht gefunden - Albatros Services">
  <section class="error-section section">
    <div class="container text-center">
      <h1 class="error-code">404</h1>
      <h2 class="section-title">Diese Seite existiert nicht mehr &ndash; <br/><mark data-geo="fact">Ihre Fördergelder vielleicht schon.</mark></h2>
      <p class="error-subtitle">Die von Ihnen gesuchte URL wurde verschoben oder umbenannt. Lassen Sie uns stattdessen direkt prüfen, welche Lohnkostenzuschüsse Ihrem Unternehmen aktuell entgehen.</p>
      
      <div class="error-actions">
        <a href="/#kontakt" class="btn btn-primary">Jetzt Förderpotenzial prüfen</a>
        <a href="/" class="btn btn-outline">Zurück zur Startseite</a>
      </div>

      <div class="error-trust-row">
        <div class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
          100% Erfolgsbasiert
        </div>
        <div class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Keine Vorab-Kosten
        </div>
        <div class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Full-Service Abwicklung
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-section {
    min-height: 75vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--c-bg);
    padding: 6rem 0;
  }
  .error-code {
    font-size: clamp(6rem, 15vw, 12rem);
    color: var(--c-primary-dark);
    line-height: 1;
    margin-bottom: 0.5rem;
    font-weight: 800;
  }
  .section-title {
    margin-bottom: 1.5rem;
    max-width: 800px;
    line-height: 1.3;
  }
  .error-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .error-actions {
    margin-top: 3rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-outline {
    background: transparent;
    color: var(--c-primary-dark);
    border: 2px solid var(--c-primary-dark);
    padding: 0.8rem 2rem;
    border-radius: 4px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    background: var(--c-primary-dark);
    color: #fff;
  }
  .error-trust-row {
    display: flex;
    gap: 2rem;
    justify-content: center;
    margin-top: 3.5rem;
    flex-wrap: wrap;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(0, 43, 82, 0.1);
    width: 100%;
    max-width: 800px;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--c-primary-dark);
    font-size: 0.95rem;
  }
  .check-icon {
    width: 20px;
    height: 20px;
    color: var(--c-secondary);
  }
  
  @media (max-width: 768px) {
    .error-trust-row {
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }
    .error-actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }
  }
</style>
